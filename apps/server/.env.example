# 环境变量参考（可选，会覆盖 config.local.json 中的同名项）
#
# 推荐：复制 config.local.example.json → config.local.json（已 gitignore，不进仓库）
#   cp config.local.example.json config.local.json
#
# 也可用环境变量覆盖（适合 CI / 临时调试）：
#   export OPENAI_API_KEY=sk-xxx
#   export OPENAI_BASE_URL=https://api.openai.com/v1
#   export OPENAI_MODEL=gpt-4o

# XX_PORT=3001
# XX_DEFAULT_PROVIDER=openai
